# Frontend (Vercel / local Next.js)
# Railway API base URL, no trailing slash — e.g. https://camp-sparkle-api.up.railway.app
APPLY_API_URL="http://localhost:4000"

# Backend (Railway) — set these in the Railway service, not on Vercel
EMAIL_TO="you@example.com"
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="Camp Sparkle <onboarding@resend.dev>"
# Comma-separated browser origins allowed to call the API directly (optional if Next proxies)
ALLOWED_ORIGINS="http://localhost:3000,https://your-app.vercel.app"
